{
  "manifest_version": 3,
  "author": "Thierry Huchard",
  "browser_specific_settings": {
    "gecko": {
      "id": "eds-contacts-integration-v162@thierryh.local",
      "strict_min_version": "140.0"
    }
  },
  "name": "EDS Contacts Integration",
  "description": "Synchronise les contacts Evolution Data Server avec Thunderbird au moyen d’un helper local installé séparément.",
  "version": "2.0.1",
  "icons": {
    "16": "icons/eds-contacts.svg",
    "32": "icons/eds-contacts.svg",
    "64": "icons/eds-contacts.svg"
  },
  "permissions": [
    "storage",
    "addressBooks",
    "alarms",
    "nativeMessaging"
  ],
  "background": {
    "page": "background.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
